{
  "name": "codemirror-lang-msil",
  "version": "0.0.1-beta.6",
  "description": "A IL mode for CodeMirror 6",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "dev": "npm run build && run-p dev-cm dev-vite",
    "dev-vite": "vite ./dev",
    "dev-cm": "node ./dev/watch.cjs src/index.ts",
    "build": "node ./build.cjs src/index.ts",
    "build-vite": "npm run build && vite build ./dev",
    "test": "cm-runtests",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "msil",
    "codemirror",
    "codemirror-mode",
    "codemirror6"
  ],
  "homepage": "https://github.com/wherewhere/codemirror-lang-msil",
  "bugs": {
    "url": "https://github.com/wherewhere/codemirror-lang-msil/issues"
  },
  "license": "MIT",
  "author": "wherewhere7",
  "contributors": [
    "wherewhere"
  ],
  "sideEffects": false,
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/wherewhere"
    },
    {
      "type": "爱发电",
      "url": "https://ifdian.net/@wherewhere"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wherewhere/codemirror-lang-msil.git"
  },
  "peerDependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/common": "^1.0.0",
    "@lezer/highlight": "^1.0.0",
    "@lezer/lr": "^1.0.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/buildhelper": "^1.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/common": "^1.0.0",
    "@lezer/generator": "^1.0.0",
    "@lezer/highlight": "^1.0.0",
    "@lezer/lr": "^1.0.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-legacy": "^8.0.0",
    "codemirror": "^6.0.0",
    "lz-string": "^1.0.0",
    "npm-run-all": "^4.0.0",
    "vite": "^8.0.0",
    "vite-plugin-simple-html": "^1.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0"
  }
}
